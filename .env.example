# Maroa.ai — environment template
# Copy to .env, fill in real values. NEVER commit .env. NEVER use these example
# values in production. Schema enforced at boot by lib/env.js — server crashes
# loudly on missing/invalid required vars.

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Release tag (use git SHA in CI). Surfaces on Sentry events.
RELEASE=

# Hatch for local dev only — set to 1 to skip env validation. NEVER set in prod.
MAROA_ENV_SKIP_VALIDATION=

# ─── Supabase (REQUIRED) ────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Anthropic (REQUIRED — one of these) ────────────────────────────────────
ANTHROPIC_KEY=
ANTHROPIC_API_KEY=

# ─── Internal-service auth (REQUIRED) ───────────────────────────────────────
# 32+ random bytes recommended. Used for webhook auth + OAuth state signing.
N8N_WEBHOOK_SECRET=<random-32-bytes>
ORCHESTRATOR_SECRET=

# ─── Sentry / observability ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── External HTTP defaults ─────────────────────────────────────────────────
# Default timeout for outbound HTTP. Streaming Claude has its own 120s budget.
EXTERNAL_HTTP_TIMEOUT_MS=15000

# ─── Inngest ────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Optional integrations ──────────────────────────────────────────────────
SERPAPI_KEY=
REPLICATE_API_KEY=
PEXELS_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_HOST=
RUNWAY_API_KEY=
GOOGLE_AI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Payments ───────────────────────────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_ENV=sandbox
PADDLE_WEBHOOK_SECRET=
PADDLE_STARTER_PRICE_ID=
PADDLE_GROWTH_PRICE_ID=
PADDLE_AGENCY_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── OAuth — Google ─────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://<api-host>/webhook/oauth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── OAuth — Meta ───────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://<api-host>/webhook/oauth/meta/callback

# Frontend (used in OAuth redirect targets)
FRONTEND_URL=https://maroa-ai-marketing-automator.lovable.app

# ─── OAuth at-rest encryption (REQUIRED if any OAuth provider is enabled) ───
# 32 random bytes, hex-encoded. Used as the symmetric key for pgp_sym_encrypt
# on OAuth tokens stored in Supabase. Rotate by generating a new key + writing
# a re-key migration. Generate with: openssl rand -hex 32
OAUTH_TOKEN_ENC_KEY=

# ─── Rate limit / cache (optional Upstash) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cost cap overrides (per plan, $/month) ─────────────────────────────────
# Override the defaults in lib/costGuard.js. Leave blank to use defaults.
COST_CAP_FREE_USD=
COST_CAP_STARTER_USD=
COST_CAP_GROWTH_USD=
COST_CAP_AGENCY_USD=
