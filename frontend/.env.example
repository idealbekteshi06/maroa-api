# ────────────────────────────────────────────────────────────────────────
# Maroa frontend — local + production env vars
# Copy to .env.local for local dev, set the same keys on Vercel for prod
# ────────────────────────────────────────────────────────────────────────

# Public site URL — used for SEO, canonical URLs, and auth callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base (your Railway deployment)
NEXT_PUBLIC_API_URL=https://maroa-api-production.up.railway.app

# Supabase Auth (frontend) — anon key is safe to ship to browsers
NEXT_PUBLIC_SUPABASE_URL=https://zqhyrbttuqkvmdewiytf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-anon-key-from-supabase-dashboard>

# Optional: Plausible / PostHog / etc.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=maroa.ai
