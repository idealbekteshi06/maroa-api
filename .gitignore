# Maroa.ai — git ignore

# Secrets & local config
.env
.env.*
# Allow the template — it has no real values
!.env.example
setup.sh

# Local scripts
trigger.js
test_everything.js

# n8n workflow JSONs (too many secrets hardcoded)
n8n-workflows/

# CLAUDE.md is intentionally tracked — it's the knowledge base for new
# engineers (and Claude itself). LEARNINGS.md is its sibling. Both must
# stay in sync with reality; CI will fail if either drifts.

# Runtime
workflow_ids.txt
node_modules/
npm-debug.log*

# macOS
.DS_Store
.claude/

# Stryker mutation reports (CI uploads these as artifacts)
reports/
.stryker-tmp/
