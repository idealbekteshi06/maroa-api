{
  "manifest_version": 3,
  "name": "Maroa — Save inspiration",
  "version": "0.1.0",
  "description": "Right-click any Instagram, Facebook, or TikTok post and save it as Maroa inspiration. Your cold-start corpus grows with every save.",
  "permissions": ["contextMenus", "activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "https://*.tiktok.com/*",
    "https://*.threads.net/*",
    "https://maroa-api-production.up.railway.app/*",
    "https://maroa.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Maroa",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*", "https://*.facebook.com/*", "https://*.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "minimum_chrome_version": "114",
  "homepage_url": "https://maroa.ai"
}
