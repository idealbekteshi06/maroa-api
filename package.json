{
  "name": "maroa-api",
  "version": "1.0.0",
  "description": "Maroa.ai webhook API server — replaces n8n webhook triggers",
  "main": "server.js",
  "scripts": {
    "build": "node scripts/sync_foundation.mjs",
    "prestart": "node scripts/sync_foundation.mjs",
    "start": "node server.js",
    "dev": "node scripts/sync_foundation.mjs && node --watch server.js",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "zod": "^4.3.6"
  },
  "keywords": [
    "maroa",
    "marketing",
    "automation",
    "webhook"
  ],
  "license": "MIT"
}
