    {
      "parameters": {
        "method": "GET",
        "url": "https://api.pexels.com/v1/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $env.PEXELS_API_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{$node['Split In Batches'].json['content_theme'] || 'business marketing'}}"
            },
            {
              "name": "per_page",
              "value": "5"
            },
            {
              "name": "orientation",
              "value": "landscape"
            }
          ]
        },
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678905",
      "name": "Search Pexels",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n  const results = [];\n  for (const item of items) {\n    const photos = item.json.photos || [];\n    const hasPhoto = photos.length > 0;\n    const imageUrl = hasPhoto ? photos[0].src.large : null;\n    results.push({json: {\n      content_id: $node['Split In Batches'].json['id'],\n      content_theme: $node['Split In Batches'].json['content_theme'] || 'business',\n      has_photo: hasPhoto,\n      image_url: imageUrl,\n      pexels_photo_id: hasPhoto ? photos[0].id : null\n    }});\n  }\n  return results;\n} catch(e) {\n  return [{json:{error: e.message, has_photo: false, content_id: $node['Split In Batches'].json.id}}];\n}"
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678906",
      "name": "Check Pexels Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-has-photo",
              "leftValue": "={{$json.has_photo}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678907",
      "name": "Has Good Photo",
