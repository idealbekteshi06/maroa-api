    {
      "parameters": {
        "method": "POST",
        "url": "https://api.replicate.com/v1/models/black-forest-labs/flux-schnell/predictions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Token ' + $env.REPLICATE_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"input\":{\"prompt\":\"Professional marketing photo for {{$node['Split In Batches'].json['content_theme']}} business, high quality, commercial photography style\"}}",
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678909",
      "name": "Generate with Replicate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1560,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n  const results = [];\n  for (const item of items) {\n    const prediction = item.json;\n    const outputUrl = Array.isArray(prediction.output) ? prediction.output[0] : (prediction.output || null);\n    results.push({json: {\n      content_id: $node['Split In Batches'].json['id'],\n      image_url: outputUrl || prediction.urls?.get || null,\n      replicate_id: prediction.id || null\n    }});\n  }\n  return results;\n} catch(e) {\n  return [{json:{error: e.message, content_id: $node['Split In Batches'].json.id, image_url: null}}];\n}"
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678910",
      "name": "Wait for Replicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
