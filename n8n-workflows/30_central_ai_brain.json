      ],
      "parameters": {
        "jsCode": "try {\n  const biz = $('Loop Each Business').first().json;\n  return [{ json: { \n    business_id: biz.id,\n    biz: biz\n  }}];\n} catch(e) {\n  return [{ json: { error: e.message } }];\n}"
      }
    },
