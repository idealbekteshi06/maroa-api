    {
      "id": "c9d0e1f2-a3b4-5678-cdef-789012345678",
      "name": "Build Intelligence Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1340,
        380
      ],
      "parameters": {
        "jsCode": "try {\n  const biz = $('Loop Each Business').first().json;\n  const perf = $('Fetch Performance Data').all().map(i => i.json);\n  const comp = $('Fetch Competitor Data').all().map(i => i.json);\n  const content = $('Fetch Content Performance').all().map(i => i.json);\n  \n  const avgRoas = perf.length ? (perf.reduce((s,p) => s+(p.roas||0),0)/perf.length).toFixed(2) : 0;\n  const avgCtr = perf.length ? (perf.reduce((s,p) => s+(p.ctr||0),0)/perf.length).toFixed(3) : 0;\n  const totalSpend = perf.reduce((s,p) => s+(p.spend||0),0).toFixed(2);\n  const approvedContent = content.filter(c => c.status === 'approved').length;\n  \n  const prompt = `You are the central AI brain for a marketing automation system. Analyze all data and build a comprehensive 30-day marketing strategy.\n\nBUSINESS PROFILE:\n- Name: ${biz.business_name}\n- Industry: ${biz.industry}\n- Location: ${biz.location}\n- Target Audience: ${biz.target_audience}\n- Brand Tone: ${biz.brand_tone}\n- Marketing Goal: ${biz.marketing_goal}\n- Plan: ${biz.plan}\n- Current ROAS: ${biz.avg_roas || 0}\n- Total Reach: ${biz.total_reach || 0}\n\nPERFORMANCE METRICS (last 10 periods):\n- Average ROAS: ${avgRoas}\n- Average CTR: ${avgCtr}%\n- Total Ad Spend: $${totalSpend}\n- Content Approval Rate: ${approvedContent}/${content.length} pieces approved\n\nCOMPETITOR LANDSCAPE:\n${comp.map(c => `- Gap: ${c.gap_opportunity || 'N/A'} | Opportunity: ${c.content_to_steal || 'N/A'}`).join('\\n') || 'No competitor data yet'}\n\nAnalyze this data and return ONLY valid JSON:\n{\n  \"strategy_summary\": \"2-3 sentence executive summary of current performance\",\n  \"top_priority\": \"single most important thing to focus on this month\",\n  \"content_direction\": \"specific content themes and angles to pursue\",\n  \"ad_strategy\": \"ad targeting and budget allocation recommendation\",\n  \"growth_levers\": [\"lever1\", \"lever2\", \"lever3\"],\n  \"risks\": [\"risk1\", \"risk2\"],\n  \"monthly_goal\": \"specific measurable goal for this month\",\n  \"recommended_budget\": \"daily ad budget recommendation in USD\",\n  \"channels_to_focus\": [\"channel1\", \"channel2\"],\n  \"quick_wins\": [\"quick win 1\", \"quick win 2\", \"quick win 3\"]\n}`;\n\n  return [{ json: { prompt, biz } }];\n} catch(e) {\n  return [{ json: { error: e.message, prompt: 'Analyze business performance and return a marketing strategy JSON', biz: {} } }];\n}"
      }
    },
    {
      "id": "d0e1f2a3-b4c5-6789-defa-890123456789",
      "name": "Call Claude Opus",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1560,
        380
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 2000, \"system\": $(\\'Fetch Business Context\\').first().json.full_master_prompt, \"messages\": [{\n    \"role\": \"user\",\n    \"content\": {{ JSON.stringify($json.prompt) }}\n  }]\n}",
        "options": {}
      }
    },
    {
      "id": "e1f2a3b4-c5d6-7890-efab-901234567890",
      "name": "Parse Strategy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        380
      ],
      "parameters": {
        "jsCode": "try {\n  const raw = $input.first().json.content?.[0]?.text || '';\n  let c = {};\n  try { c = JSON.parse(raw); }\n  catch(e) { const m = raw.match(/\\{[\\s\\S]*\\}/); if(m) try { c = JSON.parse(m[0]); } catch(e2) {} }\n  const biz = $('Build Intelligence Prompt').first().json.biz;\n  return [{ json: { strategy: JSON.stringify(c), biz, ...c } }];\n} catch(e) {\n  return [{ json: { error: e.message, strategy: '{}', biz: {} } }];\n}"
      }
    },
    {
      "id": "f2a3b4c5-d6e7-8901-fabc-012345678901",
