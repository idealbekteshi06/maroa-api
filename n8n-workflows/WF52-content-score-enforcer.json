        "method": "PATCH",
        "url": "=https://zqhyrbttuqkvmdewiytf.supabase.co/rest/v1/generated_content?id=eq.{{ $json.content_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
