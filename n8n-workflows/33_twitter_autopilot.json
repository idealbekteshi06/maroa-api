{
  "name": "33 - Twitter Autopilot",
  "active": false,
  "settings": { "executionOrder": "v1" },
  "nodes": [
    {
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
